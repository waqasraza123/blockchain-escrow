{
  "name": "@blockchain-escrow/api",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/apps/api/src/main.js",
    "lint": "eslint .",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@blockchain-escrow/contracts-sdk": "workspace:*",
    "@blockchain-escrow/db": "workspace:*",
    "@blockchain-escrow/security": "workspace:*",
    "@blockchain-escrow/shared": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "viem": "^2.38.2"
  }
}
