generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum OrganizationInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum AuditAction {
  AUTH_LOGOUT
  AUTH_NONCE_ISSUED
  AUTH_SESSION_VERIFIED
  COUNTERPARTY_CREATED
  DEAL_VERSION_ACCEPTANCE_CREATED
  DEAL_VERSION_CREATED
  DRAFT_DEAL_CREATED
  FILE_CREATED
  ORGANIZATION_CREATED
  ORGANIZATION_INVITE_REVOKED
  ORGANIZATION_INVITE_ACCEPTED
  ORGANIZATION_INVITE_CREATED
  ORGANIZATION_MEMBER_REMOVED
  ORGANIZATION_MEMBER_ROLE_UPDATED
  TEMPLATE_CREATED
}

enum AuditEntityType {
  COUNTERPARTY
  DEAL_VERSION_ACCEPTANCE
  DEAL_VERSION
  DRAFT_DEAL
  FILE
  ORGANIZATION
  ORGANIZATION_INVITE
  ORGANIZATION_MEMBER
  SESSION
  TEMPLATE
  USER
  WALLET
}

enum FileCategory {
  GENERAL
  DRAFT_ATTACHMENT
  EVIDENCE
  SIGNED_DOCUMENT
}

enum DealState {
  DRAFT
  AWAITING_SELLER_ACCEPTANCE
  AWAITING_FUNDING
  ACTIVE
  UNDER_REVIEW
  DISPUTED
  PARTIALLY_RELEASED
  COMPLETED
  REFUNDED
  CANCELLED
  EXPIRED
}

enum DealPartyRole {
  BUYER
  SELLER
}

enum DealPartySubjectType {
  ORGANIZATION
  COUNTERPARTY
}

enum SettlementCurrency {
  USDC
}

enum TypedSignatureScheme {
  EIP712
}

model User {
  id                         String                 @id @db.Text
  createdAt                  DateTime               @db.Timestamptz(3)
  updatedAt                  DateTime               @db.Timestamptz(3)
  sessions                   Session[]
  wallets                    Wallet[]
  organizationsOwned         Organization[]
  counterpartiesCreated      Counterparty[]         @relation("CounterpartyCreatedByUser")
  draftDealsCreated          DraftDeal[]            @relation("DraftDealCreatedByUser")
  dealVersionAcceptancesMade DealVersionAcceptance[] @relation("DealVersionAcceptanceAcceptedByUser")
  dealVersionsCreated        DealVersion[]          @relation("DealVersionCreatedByUser")
  filesCreated               StoredFile[]           @relation("StoredFileCreatedByUser")
  templatesCreated           Template[]             @relation("TemplateCreatedByUser")
  organizationRoles          OrganizationMember[]
  invitesSent                OrganizationInvite[]   @relation("OrganizationInviteInvitedByUser")
  auditLogs                  AuditLog[]             @relation("AuditActorUser")

  @@map("users")
}

model Wallet {
  id                    String                  @id @db.Text
  userId                String                  @db.Text
  address               String                  @unique @db.Text
  chainId               Int?
  isPrimary             Boolean
  createdAt             DateTime                @db.Timestamptz(3)
  updatedAt             DateTime                @db.Timestamptz(3)
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions              Session[]
  dealVersionAcceptances DealVersionAcceptance[] @relation("DealVersionAcceptanceSignerWallet")

  @@index([userId], map: "wallets_user_id_idx")
  @@map("wallets")
}

model WalletNonce {
  id            String   @id @db.Text
  walletAddress String   @db.Text
  chainId       Int
  nonce         String   @unique @db.Text
  createdAt     DateTime @db.Timestamptz(3)
  expiresAt     DateTime @db.Timestamptz(3)
  consumedAt    DateTime? @db.Timestamptz(3)

  @@index([walletAddress], map: "wallet_nonces_wallet_address_idx")
  @@index([expiresAt], map: "wallet_nonces_expires_at_idx")
  @@map("wallet_nonces")
}

model Session {
  id         String        @id @db.Text
  userId     String        @db.Text
  walletId   String        @db.Text
  tokenHash  String        @unique @db.Text
  status     SessionStatus
  createdAt  DateTime      @db.Timestamptz(3)
  expiresAt  DateTime      @db.Timestamptz(3)
  lastSeenAt DateTime?     @db.Timestamptz(3)
  revokedAt  DateTime?     @db.Timestamptz(3)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet     Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_idx")
  @@index([walletId], map: "sessions_wallet_id_idx")
  @@index([status], map: "sessions_status_idx")
  @@map("sessions")
}

model Organization {
  id                     String                  @id @db.Text
  createdByUserId        String                  @db.Text
  name                   String                  @db.Text
  slug                   String                  @unique @db.Text
  createdAt              DateTime                @db.Timestamptz(3)
  updatedAt              DateTime                @db.Timestamptz(3)
  createdByUser          User                    @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  counterparties         Counterparty[]
  dealVersionAcceptances DealVersionAcceptance[]
  dealVersionParties     DealVersionParty[]      @relation("DealVersionPartyOrganization")
  dealVersions           DealVersion[]
  draftDealParties       DraftDealParty[]        @relation("DraftDealPartyOrganization")
  draftDeals             DraftDeal[]
  files                  StoredFile[]
  templates              Template[]
  members                OrganizationMember[]
  invites                OrganizationInvite[]
  auditLogs              AuditLog[]

  @@index([createdByUserId], map: "organizations_created_by_user_id_idx")
  @@map("organizations")
}

model Counterparty {
  id              String       @id @db.Text
  organizationId  String       @db.Text
  createdByUserId String       @db.Text
  name            String       @db.Text
  normalizedName  String       @db.Text
  legalName       String?      @db.Text
  contactEmail    String?      @db.Text
  createdAt       DateTime     @db.Timestamptz(3)
  updatedAt       DateTime     @db.Timestamptz(3)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser   User         @relation("CounterpartyCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  dealVersionParties DealVersionParty[] @relation("DealVersionPartyCounterparty")
  draftDealParties DraftDealParty[]     @relation("DraftDealPartyCounterparty")
  templatesAsDefault Template[] @relation("TemplateDefaultCounterparty")

  @@unique([organizationId, normalizedName], map: "counterparties_organization_id_normalized_name_key")
  @@index([organizationId], map: "counterparties_organization_id_idx")
  @@index([createdByUserId], map: "counterparties_created_by_user_id_idx")
  @@index([organizationId, createdAt], map: "counterparties_organization_id_created_at_idx")
  @@map("counterparties")
}

model StoredFile {
  id               String       @id @db.Text
  organizationId   String       @db.Text
  createdByUserId  String       @db.Text
  originalFilename String       @db.Text
  mediaType        String       @db.Text
  byteSize         BigInt
  sha256Hex        String       @db.Text
  storageKey       String       @db.Text
  category         FileCategory
  createdAt        DateTime     @db.Timestamptz(3)
  updatedAt        DateTime     @db.Timestamptz(3)
  dealVersionFiles DealVersionFile[]
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser    User         @relation("StoredFileCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@unique([organizationId, storageKey], map: "files_organization_id_storage_key_key")
  @@index([organizationId], map: "files_organization_id_idx")
  @@index([createdByUserId], map: "files_created_by_user_id_idx")
  @@index([organizationId, createdAt], map: "files_organization_id_created_at_idx")
  @@map("files")
}

model Template {
  id                  String       @id @db.Text
  organizationId      String       @db.Text
  createdByUserId     String       @db.Text
  defaultCounterpartyId String?    @db.Text
  name                String       @db.Text
  normalizedName      String       @db.Text
  description         String?      @db.Text
  bodyMarkdown        String       @db.Text
  createdAt           DateTime     @db.Timestamptz(3)
  updatedAt           DateTime     @db.Timestamptz(3)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser       User         @relation("TemplateCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  defaultCounterparty Counterparty? @relation("TemplateDefaultCounterparty", fields: [defaultCounterpartyId], references: [id], onDelete: SetNull)
  dealVersions        DealVersion[]  @relation("DealVersionTemplate")
  draftDeals          DraftDeal[]    @relation("DraftDealTemplate")

  @@unique([organizationId, normalizedName], map: "templates_organization_id_normalized_name_key")
  @@index([organizationId], map: "templates_organization_id_idx")
  @@index([createdByUserId], map: "templates_created_by_user_id_idx")
  @@index([defaultCounterpartyId], map: "templates_default_counterparty_id_idx")
  @@index([organizationId, createdAt], map: "templates_organization_id_created_at_idx")
  @@map("templates")
}

model DraftDeal {
  id                 String             @id @db.Text
  organizationId     String             @db.Text
  createdByUserId    String             @db.Text
  templateId         String?            @db.Text
  title              String             @db.Text
  summary            String?            @db.Text
  settlementCurrency SettlementCurrency
  state              DealState
  createdAt          DateTime           @db.Timestamptz(3)
  updatedAt          DateTime           @db.Timestamptz(3)
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser      User               @relation("DraftDealCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  template           Template?          @relation("DraftDealTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  parties            DraftDealParty[]
  versions           DealVersion[]

  @@index([organizationId], map: "draft_deals_organization_id_idx")
  @@index([createdByUserId], map: "draft_deals_created_by_user_id_idx")
  @@index([templateId], map: "draft_deals_template_id_idx")
  @@index([organizationId, createdAt], map: "draft_deals_organization_id_created_at_idx")
  @@map("draft_deals")
}

model DraftDealParty {
  id             String              @id @db.Text
  draftDealId    String              @db.Text
  role           DealPartyRole
  subjectType    DealPartySubjectType
  organizationId String?             @db.Text
  counterpartyId String?             @db.Text
  createdAt      DateTime            @db.Timestamptz(3)
  updatedAt      DateTime            @db.Timestamptz(3)
  draftDeal      DraftDeal           @relation(fields: [draftDealId], references: [id], onDelete: Cascade)
  organization   Organization?       @relation("DraftDealPartyOrganization", fields: [organizationId], references: [id], onDelete: SetNull)
  counterparty   Counterparty?       @relation("DraftDealPartyCounterparty", fields: [counterpartyId], references: [id], onDelete: SetNull)

  @@unique([draftDealId, role], map: "draft_deal_parties_draft_deal_id_role_key")
  @@index([draftDealId], map: "draft_deal_parties_draft_deal_id_idx")
  @@index([organizationId], map: "draft_deal_parties_organization_id_idx")
  @@index([counterpartyId], map: "draft_deal_parties_counterparty_id_idx")
  @@map("draft_deal_parties")
}

model DealVersion {
  id                 String             @id @db.Text
  draftDealId        String             @db.Text
  organizationId     String             @db.Text
  createdByUserId    String             @db.Text
  templateId         String?            @db.Text
  versionNumber      Int
  title              String             @db.Text
  summary            String?            @db.Text
  settlementCurrency SettlementCurrency
  bodyMarkdown       String             @db.Text
  createdAt          DateTime           @db.Timestamptz(3)
  draftDeal          DraftDeal          @relation(fields: [draftDealId], references: [id], onDelete: Cascade)
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser      User               @relation("DealVersionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  template           Template?          @relation("DealVersionTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  acceptances        DealVersionAcceptance[]
  parties            DealVersionParty[]
  milestones         DealVersionMilestone[]
  files              DealVersionFile[]

  @@unique([draftDealId, versionNumber], map: "deal_versions_draft_deal_id_version_number_key")
  @@index([draftDealId], map: "deal_versions_draft_deal_id_idx")
  @@index([organizationId], map: "deal_versions_organization_id_idx")
  @@index([createdByUserId], map: "deal_versions_created_by_user_id_idx")
  @@index([templateId], map: "deal_versions_template_id_idx")
  @@index([draftDealId, createdAt], map: "deal_versions_draft_deal_id_created_at_idx")
  @@map("deal_versions")
}

model DealVersionParty {
  id             String              @id @db.Text
  dealVersionId  String              @db.Text
  role           DealPartyRole
  subjectType    DealPartySubjectType
  organizationId String?             @db.Text
  counterpartyId String?             @db.Text
  displayName    String              @db.Text
  createdAt      DateTime            @db.Timestamptz(3)
  dealVersion    DealVersion             @relation(fields: [dealVersionId], references: [id], onDelete: Cascade)
  organization   Organization?           @relation("DealVersionPartyOrganization", fields: [organizationId], references: [id], onDelete: SetNull)
  counterparty   Counterparty?           @relation("DealVersionPartyCounterparty", fields: [counterpartyId], references: [id], onDelete: SetNull)
  acceptances    DealVersionAcceptance[]

  @@unique([dealVersionId, role], map: "deal_version_parties_deal_version_id_role_key")
  @@index([dealVersionId], map: "deal_version_parties_deal_version_id_idx")
  @@index([organizationId], map: "deal_version_parties_organization_id_idx")
  @@index([counterpartyId], map: "deal_version_parties_counterparty_id_idx")
  @@map("deal_version_parties")
}

model DealVersionMilestone {
  id            String      @id @db.Text
  dealVersionId String      @db.Text
  position      Int
  title         String      @db.Text
  description   String?     @db.Text
  amountMinor   String      @db.Text
  dueAt         DateTime?   @db.Timestamptz(3)
  createdAt     DateTime    @db.Timestamptz(3)
  dealVersion   DealVersion @relation(fields: [dealVersionId], references: [id], onDelete: Cascade)

  @@unique([dealVersionId, position], map: "deal_version_milestones_deal_version_id_position_key")
  @@index([dealVersionId], map: "deal_version_milestones_deal_version_id_idx")
  @@map("deal_version_milestones")
}

model DealVersionFile {
  id            String      @id @db.Text
  dealVersionId String      @db.Text
  fileId        String      @db.Text
  createdAt     DateTime    @db.Timestamptz(3)
  dealVersion   DealVersion @relation(fields: [dealVersionId], references: [id], onDelete: Cascade)
  file          StoredFile  @relation(fields: [fileId], references: [id], onDelete: Restrict)

  @@unique([dealVersionId, fileId], map: "deal_version_files_deal_version_id_file_id_key")
  @@index([dealVersionId], map: "deal_version_files_deal_version_id_idx")
  @@index([fileId], map: "deal_version_files_file_id_idx")
  @@map("deal_version_files")
}

model DealVersionAcceptance {
  id                String               @id @db.Text
  dealVersionId     String               @db.Text
  dealVersionPartyId String              @db.Text
  organizationId    String               @db.Text
  acceptedByUserId  String               @db.Text
  signerWalletId    String               @db.Text
  signerWalletAddress String             @db.Text
  scheme            TypedSignatureScheme
  signature         String               @db.Text
  typedData         Json
  acceptedAt        DateTime             @db.Timestamptz(3)
  dealVersion       DealVersion          @relation(fields: [dealVersionId], references: [id], onDelete: Cascade)
  dealVersionParty  DealVersionParty     @relation(fields: [dealVersionPartyId], references: [id], onDelete: Cascade)
  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  acceptedByUser    User                 @relation("DealVersionAcceptanceAcceptedByUser", fields: [acceptedByUserId], references: [id], onDelete: Restrict)
  signerWallet      Wallet               @relation("DealVersionAcceptanceSignerWallet", fields: [signerWalletId], references: [id], onDelete: Restrict)

  @@unique([dealVersionPartyId], map: "deal_version_acceptances_deal_version_party_id_key")
  @@index([dealVersionId], map: "deal_version_acceptances_deal_version_id_idx")
  @@index([organizationId], map: "deal_version_acceptances_organization_id_idx")
  @@index([acceptedByUserId], map: "deal_version_acceptances_accepted_by_user_id_idx")
  @@index([signerWalletId], map: "deal_version_acceptances_signer_wallet_id_idx")
  @@index([dealVersionId, acceptedAt], map: "deal_version_acceptances_deal_version_id_accepted_at_idx")
  @@map("deal_version_acceptances")
}

model OrganizationMember {
  id             String           @id @db.Text
  organizationId String           @db.Text
  userId         String           @db.Text
  role           OrganizationRole
  createdAt      DateTime         @db.Timestamptz(3)
  updatedAt      DateTime         @db.Timestamptz(3)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId], map: "organization_members_organization_id_user_id_key")
  @@index([userId], map: "organization_members_user_id_idx")
  @@index([organizationId], map: "organization_members_organization_id_idx")
  @@map("organization_members")
}

model OrganizationInvite {
  id              String                   @id @db.Text
  organizationId  String                   @db.Text
  invitedByUserId String                   @db.Text
  email           String                   @db.Text
  role            OrganizationRole
  status          OrganizationInviteStatus
  tokenHash       String                   @unique @db.Text
  createdAt       DateTime                 @db.Timestamptz(3)
  updatedAt       DateTime                 @db.Timestamptz(3)
  expiresAt       DateTime                 @db.Timestamptz(3)
  acceptedAt      DateTime?                @db.Timestamptz(3)
  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedByUser   User                     @relation("OrganizationInviteInvitedByUser", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@index([organizationId], map: "organization_invites_organization_id_idx")
  @@index([email], map: "organization_invites_email_idx")
  @@index([status], map: "organization_invites_status_idx")
  @@map("organization_invites")
}

model AuditLog {
  id             String          @id @db.Text
  action         AuditAction
  actorUserId    String?         @db.Text
  entityType     AuditEntityType
  entityId       String          @db.Text
  organizationId String?         @db.Text
  metadata       Json?
  ipAddress      String?         @db.Text
  userAgent      String?         @db.Text
  occurredAt     DateTime        @db.Timestamptz(3)
  actorUser      User?           @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId], map: "audit_logs_entity_type_entity_id_idx")
  @@index([organizationId], map: "audit_logs_organization_id_idx")
  @@index([actorUserId], map: "audit_logs_actor_user_id_idx")
  @@map("audit_logs")
}
