model User {
  id                         String                 @id @db.Text
  createdAt                  DateTime               @db.Timestamptz(3)
  updatedAt                  DateTime               @db.Timestamptz(3)
  approvalPoliciesCreated    ApprovalPolicy[]       @relation("ApprovalPolicyCreatedByUser")
  approvalRequestsRequested  ApprovalRequest[]      @relation("ApprovalRequestRequestedByUser")
  approvalRequestStepsDecided ApprovalRequestStep[] @relation("ApprovalRequestStepDecidedByUser")
  costCentersCreated         CostCenter[]           @relation("CostCenterCreatedByUser")
  sessions                   Session[]
  statementSnapshotsCreated  StatementSnapshot[]    @relation("StatementSnapshotCreatedByUser")
  wallets                    Wallet[]
  organizationsOwned         Organization[]
  operatorAccounts           OperatorAccount[]
  counterpartiesCreated      Counterparty[]         @relation("CounterpartyCreatedByUser")
  dealMilestoneDisputeAssignmentsMade DealMilestoneDisputeAssignment[] @relation("DealMilestoneDisputeAssignmentAssignedByUser")
  dealMilestoneDisputesOpened DealMilestoneDispute[] @relation("DealMilestoneDisputeOpenedByUser")
  dealMilestoneReviewsMade   DealMilestoneReview[]  @relation("DealMilestoneReviewReviewedByUser")
  dealMilestoneSettlementExecutionTransactionsSubmitted DealMilestoneSettlementExecutionTransaction[] @relation("DealMilestoneSettlementExecutionTransactionSubmittedByUser")
  dealMilestoneSettlementRequestsMade DealMilestoneSettlementRequest[] @relation("DealMilestoneSettlementRequestRequestedByUser")
  draftDealsCreated          DraftDeal[]            @relation("DraftDealCreatedByUser")
  dealVersionAcceptancesMade DealVersionAcceptance[] @relation("DealVersionAcceptanceAcceptedByUser")
  dealVersionsCreated        DealVersion[]          @relation("DealVersionCreatedByUser")
  dealMilestoneSubmissionsMade DealMilestoneSubmission[] @relation("DealMilestoneSubmissionSubmittedByUser")
  filesCreated               StoredFile[]           @relation("StoredFileCreatedByUser")
  fundingTransactionsSubmitted FundingTransaction[] @relation("FundingTransactionSubmittedByUser")
  templatesCreated           Template[]             @relation("TemplateCreatedByUser")
  financeExportJobsCreated   FinanceExportJob[]     @relation("FinanceExportJobCreatedByUser")
  gasPoliciesCreated         GasPolicy[]            @relation("GasPolicyCreatedByUser")
  organizationRoles          OrganizationMember[]
  invitesSent                OrganizationInvite[]   @relation("OrganizationInviteInvitedByUser")
  auditLogs                  AuditLog[]             @relation("AuditActorUser")
  sponsoredTransactionRequests SponsoredTransactionRequest[] @relation("SponsoredTransactionRequestRequestedByUser")

  @@map("users")
}

model Wallet {
  id                    String                  @id @db.Text
  userId                String                  @db.Text
  address               String                  @unique @db.Text
  chainId               Int?
  isPrimary             Boolean
  createdAt             DateTime                @db.Timestamptz(3)
  updatedAt             DateTime                @db.Timestamptz(3)
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  operatorAccounts      OperatorAccount[]
  sessions              Session[]
  dealVersionAcceptances DealVersionAcceptance[] @relation("DealVersionAcceptanceSignerWallet")
  dealMilestoneSettlementExecutionTransactionsSubmitted DealMilestoneSettlementExecutionTransaction[] @relation("DealMilestoneSettlementExecutionTransactionSubmittedWallet")
  fundingTransactionsSubmitted FundingTransaction[] @relation("FundingTransactionSubmittedWallet")
  profile               WalletProfile?
  sponsoredTransactionRequests SponsoredTransactionRequest[]

  @@index([userId], map: "wallets_user_id_idx")
  @@map("wallets")
}

model WalletProfile {
  walletId                      String    @id @db.Text
  displayName                   String    @db.Text
  defaultOrganizationId         String?   @db.Text
  defaultGasPolicyId            String?   @db.Text
  sponsorTransactionsByDefault  Boolean
  approvalNoteTemplate          String?   @db.Text
  reviewNoteTemplate            String?   @db.Text
  createdAt                     DateTime  @db.Timestamptz(3)
  updatedAt                     DateTime  @db.Timestamptz(3)
  wallet                        Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_profiles")
}

model WalletNonce {
  id            String   @id @db.Text
  walletAddress String   @db.Text
  chainId       Int
  nonce         String   @unique @db.Text
  createdAt     DateTime @db.Timestamptz(3)
  expiresAt     DateTime @db.Timestamptz(3)
  consumedAt    DateTime? @db.Timestamptz(3)

  @@index([walletAddress], map: "wallet_nonces_wallet_address_idx")
  @@index([expiresAt], map: "wallet_nonces_expires_at_idx")
  @@map("wallet_nonces")
}

model Session {
  id         String        @id @db.Text
  userId     String        @db.Text
  walletId   String        @db.Text
  tokenHash  String        @unique @db.Text
  status     SessionStatus
  createdAt  DateTime      @db.Timestamptz(3)
  expiresAt  DateTime      @db.Timestamptz(3)
  lastSeenAt DateTime?     @db.Timestamptz(3)
  revokedAt  DateTime?     @db.Timestamptz(3)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet     Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_idx")
  @@index([walletId], map: "sessions_wallet_id_idx")
  @@index([status], map: "sessions_status_idx")
  @@map("sessions")
}

model OperatorAccount {
  id         String       @id @db.Text
  userId     String       @db.Text
  walletId   String       @db.Text
  role       OperatorRole
  active     Boolean
  createdAt  DateTime     @db.Timestamptz(3)
  updatedAt  DateTime     @db.Timestamptz(3)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet     Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  acknowledgedAlerts OperatorAlert[] @relation("OperatorAlertAcknowledgedByOperator")
  assignedAlerts OperatorAlert[]     @relation("OperatorAlertAssignedOperator")
  resolvedAlerts OperatorAlert[]     @relation("OperatorAlertResolvedByOperator")
  assignedComplianceCases ComplianceCase[] @relation("ComplianceCaseAssignedOperator")
  createdComplianceCases ComplianceCase[]   @relation("ComplianceCaseCreatedByOperator")
  complianceCaseNotes ComplianceCaseNote[]  @relation("ComplianceCaseNoteAuthoredByOperator")
  createdComplianceCheckpoints ComplianceCheckpoint[] @relation("ComplianceCheckpointCreatedByOperator")
  decidedComplianceCheckpoints ComplianceCheckpoint[] @relation("ComplianceCheckpointDecidedByOperator")
  createdProtocolProposalDrafts ProtocolProposalDraft[]
  decidedSponsoredTransactionRequests SponsoredTransactionRequest[] @relation("SponsoredTransactionRequestDecidedByOperator")

  @@unique([walletId], map: "operator_accounts_wallet_id_key")
  @@index([userId], map: "operator_accounts_user_id_idx")
  @@index([role], map: "operator_accounts_role_idx")
  @@index([active], map: "operator_accounts_active_idx")
  @@map("operator_accounts")
}

model Organization {
  id                     String                  @id @db.Text
  createdByUserId        String                  @db.Text
  name                   String                  @db.Text
  slug                   String                  @unique @db.Text
  createdAt              DateTime                @db.Timestamptz(3)
  updatedAt              DateTime                @db.Timestamptz(3)
  approvalPolicies       ApprovalPolicy[]
  approvalRequests       ApprovalRequest[]
  costCenters            CostCenter[]
  createdByUser          User                    @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  counterparties         Counterparty[]
  dealMilestoneDisputeAssignments DealMilestoneDisputeAssignment[]
  dealMilestoneDisputeDecisions DealMilestoneDisputeDecision[]
  dealMilestoneDisputes  DealMilestoneDispute[]
  dealMilestoneReviewDeadlineExpiries DealMilestoneReviewDeadlineExpiry[]
  dealMilestoneSettlementExecutionTransactions DealMilestoneSettlementExecutionTransaction[]
  dealMilestoneSettlementPreparations DealMilestoneSettlementPreparation[]
  dealMilestoneReviews   DealMilestoneReview[]
  dealMilestoneSettlementRequests DealMilestoneSettlementRequest[]
  dealMilestoneSubmissions DealMilestoneSubmission[]
  dealVersionAcceptances DealVersionAcceptance[]
  dealVersionParties     DealVersionParty[]      @relation("DealVersionPartyOrganization")
  dealVersions           DealVersion[]
  draftDealParties       DraftDealParty[]        @relation("DraftDealPartyOrganization")
  draftDeals             DraftDeal[]
  files                  StoredFile[]
  fundingTransactions    FundingTransaction[]
  financeExportJobs      FinanceExportJob[]
  complianceCases        ComplianceCase[]
  complianceCheckpoints  ComplianceCheckpoint[]
  operatorAlerts         OperatorAlert[]
  statementSnapshots     StatementSnapshot[]
  templates              Template[]
  members                OrganizationMember[]
  invites                OrganizationInvite[]
  auditLogs              AuditLog[]
  gasPolicies            GasPolicy[]
  sponsoredTransactionRequests SponsoredTransactionRequest[]
  usageMeterEvents       BillingUsageMeterEvent[]

  @@index([createdByUserId], map: "organizations_created_by_user_id_idx")
  @@map("organizations")
}

model GasPolicy {
  id                          String                     @id @db.Text
  organizationId              String                     @db.Text
  createdByUserId             String                     @db.Text
  name                        String                     @db.Text
  description                 String?                    @db.Text
  active                      Boolean
  allowedTransactionKinds     SponsoredTransactionKind[]
  allowedApprovalPolicyKinds  ApprovalPolicyKind[]
  allowedChainIds             Int[]
  maxAmountMinor              String?                    @db.Text
  maxRequestsPerDay           Int
  sponsorWindowMinutes        Int
  createdAt                   DateTime                   @db.Timestamptz(3)
  updatedAt                   DateTime                   @db.Timestamptz(3)
  organization                Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser               User                       @relation("GasPolicyCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  sponsoredTransactionRequests SponsoredTransactionRequest[]

  @@index([organizationId], map: "gas_policies_organization_id_idx")
  @@index([createdByUserId], map: "gas_policies_created_by_user_id_idx")
  @@index([active], map: "gas_policies_active_idx")
  @@map("gas_policies")
}

model SponsoredTransactionRequest {
  id                              String                     @id @db.Text
  organizationId                  String                     @db.Text
  gasPolicyId                     String?                    @db.Text
  requestedByUserId               String                     @db.Text
  walletId                        String                     @db.Text
  decidedByOperatorAccountId      String?                    @db.Text
  walletAddress                   String                     @db.Text
  kind                            SponsoredTransactionKind
  status                          SponsoredTransactionStatus
  reason                          String?                    @db.Text
  subjectType                     String                     @db.Text
  subjectId                       String                     @db.Text
  draftDealId                     String?                    @db.Text
  dealVersionId                   String?                    @db.Text
  dealMilestoneSettlementRequestId String?                  @db.Text
  chainId                         Int
  toAddress                       String                     @db.Text
  data                            String                     @db.Text
  value                           String                     @db.Text
  amountMinor                     String                     @db.Text
  expiresAt                       DateTime                   @db.Timestamptz(3)
  approvedAt                      DateTime?                  @db.Timestamptz(3)
  rejectedAt                      DateTime?                  @db.Timestamptz(3)
  submittedAt                     DateTime?                  @db.Timestamptz(3)
  submittedTransactionHash        String?                    @db.Text
  createdAt                       DateTime                   @db.Timestamptz(3)
  updatedAt                       DateTime                   @db.Timestamptz(3)
  organization                    Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gasPolicy                       GasPolicy?                 @relation(fields: [gasPolicyId], references: [id], onDelete: SetNull)
  requestedByUser                 User                       @relation("SponsoredTransactionRequestRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  wallet                          Wallet                     @relation(fields: [walletId], references: [id], onDelete: Cascade)
  decidedByOperator               OperatorAccount?           @relation("SponsoredTransactionRequestDecidedByOperator", fields: [decidedByOperatorAccountId], references: [id], onDelete: SetNull)

  @@index([organizationId], map: "sponsored_transaction_requests_organization_id_idx")
  @@index([gasPolicyId], map: "sponsored_transaction_requests_gas_policy_id_idx")
  @@index([requestedByUserId], map: "sponsored_transaction_requests_requested_by_user_id_idx")
  @@index([walletId], map: "sponsored_transaction_requests_wallet_id_idx")
  @@index([decidedByOperatorAccountId], map: "sponsored_tx_requests_decided_by_operator_idx")
  @@index([status], map: "sponsored_transaction_requests_status_idx")
  @@index([status, submittedAt, expiresAt], map: "sponsored_transaction_requests_lifecycle_idx")
  @@index([subjectType, subjectId], map: "sponsored_transaction_requests_subject_idx")
  @@index([createdAt], map: "sponsored_transaction_requests_created_at_idx")
  @@map("sponsored_transaction_requests")
}

model CostCenter {
