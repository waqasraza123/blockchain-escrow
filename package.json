{
  "name": "blockchain-escrow",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "db:generate": "node scripts/with-local-env.mjs pnpm --filter @blockchain-escrow/db run prisma:generate",
    "db:migrate:deploy": "node scripts/with-local-env.mjs pnpm --filter @blockchain-escrow/db run prisma:migrate:deploy",
    "db:migrate:status": "node scripts/with-local-env.mjs pnpm --filter @blockchain-escrow/db run prisma:migrate:status",
    "dev": "node scripts/with-local-env.mjs turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "setup:githooks": "./scripts/setup-githooks.sh",
    "verify:push": "./scripts/verify-push.sh",
    "safe-push": "./scripts/safe-push.sh",
    "boot:infra": "node scripts/with-local-env.mjs docker compose up -d",
    "stop:infra": "node scripts/with-local-env.mjs docker compose down",
    "contracts:build": "pnpm --filter @blockchain-escrow/contracts run build:contracts",
    "contracts:test": "pnpm --filter @blockchain-escrow/contracts run test:contracts",
    "contracts:deploy:base-sepolia": "node scripts/with-local-env.mjs pnpm --filter @blockchain-escrow/contracts run deploy:base-sepolia",
    "contracts:export-sdk": "node scripts/with-local-env.mjs pnpm --filter @blockchain-escrow/contracts run export:contracts-sdk",
    "contracts:verify:base-sepolia": "node scripts/with-local-env.mjs pnpm --filter @blockchain-escrow/contracts run verify:base-sepolia",
    "contracts:release:base-sepolia": "node scripts/with-local-env.mjs pnpm --filter @blockchain-escrow/contracts run release:base-sepolia",
    "contracts:release:base-sepolia:fixture": "node scripts/with-local-env.mjs pnpm --filter @blockchain-escrow/contracts run release:base-sepolia:fixture",
    "release4:doctor:local": "node scripts/release4-doctor-local.mjs",
    "release4:bootstrap:local": "node scripts/release4-bootstrap-local.mjs",
    "release4:reset:local": "node scripts/with-local-env.mjs pnpm --filter @blockchain-escrow/indexer exec tsx src/reset-local.ts",
    "release4:verify:local": "node scripts/release4-verify-local.mjs",
    "e2e:seed": "node scripts/run-e2e.mjs seed",
    "e2e:reset": "node scripts/run-e2e.mjs reset",
    "e2e:smoke": "node scripts/run-e2e.mjs smoke",
    "e2e:regression": "node scripts/run-e2e.mjs regression",
    "e2e:visual": "node scripts/run-e2e.mjs visual",
    "e2e:ui": "node scripts/run-e2e.mjs ui",
    "e2e:install": "pnpm --filter @blockchain-escrow/e2e run install:browsers"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "tsx": "^4.19.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "8.57.2"
  }
}
