{
  "name": "blockchain-escrow",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "boot:infra": "docker compose up -d",
    "stop:infra": "docker compose down",
    "contracts:build": "pnpm --filter @blockchain-escrow/contracts run build:contracts",
    "contracts:test": "pnpm --filter @blockchain-escrow/contracts run test:contracts"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "tsx": "^4.19.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "8.57.2"
  }
}
